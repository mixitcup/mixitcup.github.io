<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ description or 'Mix it Cup 2026 – Trampolinwettkampf des HSP Münster Trampolin n.e.V. 20.–22. November 2026.' }}">
  <meta name="robots" content="noindex, nofollow">
  <title>{{ title }} – Mix it-Cup 2026</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
</head>
<body>

  <!-- Navigation -->
  <nav class="site-nav" aria-label="Hauptnavigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Mix it Cup Startseite">
        <img src="/assets/img/Logo-dark.svg" alt="Mix it Cup" width="162" height="60">
      </a>

      <button class="nav-toggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="nav-links">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="nav-links" id="nav-links" role="list">
        <li><a href="/" class="{{ 'active' if page.url == '/' }}">Start</a></li>
        <li><a href="/wettkampf/" class="{{ 'active' if page.url == '/wettkampf/' }}">Wettkampf</a></li>
        <li><a href="/ablauf/" class="{{ 'active' if page.url == '/ablauf/' }}">Ablauf</a></li>
        <li><a href="/merch/" class="{{ 'active' if page.url == '/merch/' }}">Merch</a></li>
        <li><a href="/meldung/" class="{{ 'active' if page.url == '/meldung/' }}">Meldung</a></li>
        <li><a href="/anreise/" class="{{ 'active' if page.url == '/anreise/' }}">Anreise</a></li>
        <li><a href="/awareness/" class="{{ 'active' if page.url == '/awareness/' }}">Awareness</a></li>
      </ul>
    </div>
  </nav>

  <!-- Main Content -->
  <main id="main-content">
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-logo">
        <img src="/assets/img/Logo-white.svg" alt="Mix it Cup" width="208" height="78">
        <span style="font-family:'Fredoka One',sans-serif; font-size:2rem; color:rgba(255,255,255,0.6); margin-left:0.3rem;">2026</span>
      </div>
      <p><i>Der offizielle Hochschulsport der Universität Münster ist nicht für die Inhalte verantwortlich.</i></p>
      <p style="margin-top:0.5rem;">
        Universitätssporthalle · Horstmarer Landweg 51 · 48149 Münster
      </p>
      <p style="margin-top:1rem;">
        <a href="mailto:mixitcup.orga@uni-muenster.de">mixitcup.orga@uni-muenster.de</a>
        &nbsp;·&nbsp;
        <a href="/ausschreibung.pdf" target="_blank" rel="noopener">Ausschreibung als PDF</a>
      </p>
      <p style="margin-top:0.5rem; font-family:'Fredoka One',sans-serif; letter-spacing:0.05em;">
        <a href="https://www.instagram.com/hsp_ms_trampolin?igsh=NjZmcXl4bHFuNG9s" target="_blank" rel="noopener" style="color:inherit;">#mixitcup2026</a>
      </p>
      <p style="margin-top:1rem; opacity:0.5; font-size:0.8rem;">
        &copy; 2026 HSP Trampolin Münster n.e.V.
      </p>
    </div>
  </footer>

  <!-- Countdown + Mobile Nav JS -->
  <script src="/assets/js/main.js"></script>
</body>
</html>
