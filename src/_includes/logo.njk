{#
  Mix it Cup Logo als SVG mit Texture-Patterns.
  Parameter:
    size   – font-size in px (default 48)
    id     – eindeutiges Suffix für Pattern-IDs (wichtig wenn mehrfach auf einer Seite!)
#}
{% set _size = size or 48 %}
{% set _id = id or "logo" %}

<!--
  Logo rendert "Mix" + "it" + " " + "Cup" als zusammengesetztes SVG.
  "Mix" leicht links geneigt (-5°), "it" aufrecht (kerning direkt an Mix),
  "Cup" leicht rechts geneigt (+4°).
  Muster: Erdbeerpunkte / Limettenkerne / Orangenhaut
-->
<svg
  viewBox="0 0 {{ (_size * 5.4) | round }} {{ (_size * 1.5) | round }}"
  width="{{ (_size * 5.4) | round }}"
  height="{{ (_size * 1.5) | round }}"
  xmlns="http://www.w3.org/2000/svg"
  aria-label="Mix it Cup"
  role="img"
  style="display:inline-block; vertical-align:middle; overflow:visible;"
>
  <defs>

    <!-- ERDBEERPUNKTE für "Mix" (rot) -->
    <pattern id="pat-strawberry-{{ _id }}" patternUnits="userSpaceOnUse" width="11" height="11">
      <rect width="11" height="11" fill="#e8294a"/>
      <ellipse cx="2.5" cy="2.5" rx="1.1" ry="1.4" fill="#b01030" opacity="0.8"  transform="rotate(-20,2.5,2.5)"/>
      <ellipse cx="7.5" cy="1.8" rx="1.0" ry="1.3" fill="#b01030" opacity="0.7"  transform="rotate(15,7.5,1.8)"/>
      <ellipse cx="1.5" cy="7.5" rx="1.0" ry="1.3" fill="#b01030" opacity="0.65" transform="rotate(25,1.5,7.5)"/>
      <ellipse cx="6.5" cy="7.5" rx="1.2" ry="1.0" fill="#b01030" opacity="0.75" transform="rotate(-8,6.5,7.5)"/>
      <ellipse cx="10"  cy="5.5" rx="0.9" ry="1.2" fill="#b01030" opacity="0.6"  transform="rotate(30,10,5.5)"/>
      <ellipse cx="4"   cy="5"   rx="0.8" ry="1.1" fill="#ff6080" opacity="0.35"/>
      <ellipse cx="9"   cy="9.5" rx="1.0" ry="0.9" fill="#b01030" opacity="0.55" transform="rotate(-12,9,9.5)"/>
    </pattern>

    <!-- LIMETTENKERNE für "it" (grün) -->
    <!-- Wenige helle Kerne, locker verteilt auf großer Pattern-Kachel -->
    <pattern id="pat-lime-{{ _id }}" patternUnits="userSpaceOnUse" width="20" height="18">
      <rect width="20" height="18" fill="#4daa20"/>
      <rect width="20" height="18" fill="#72cc40" opacity="0.25"/>
      <!-- Kern 1 -->
      <ellipse cx="5" cy="5" rx="0.85" ry="2.5" fill="#e8dfc0" opacity="0.85" transform="rotate(-15,5,5)"/>
      <line x1="5" y1="3" x2="4.7" y2="7" stroke="#8a7a40" stroke-width="0.3" opacity="0.35"/>
      <!-- Kern 2 -->
      <ellipse cx="15" cy="12" rx="0.8" ry="2.3" fill="#ece3c8" opacity="0.8" transform="rotate(12,15,12)"/>
      <line x1="15" y1="10.2" x2="15.3" y2="13.8" stroke="#8a7a40" stroke-width="0.3" opacity="0.3"/>
    </pattern>

    <!-- ORANGENHAUT für "Cup" (orange) -->
    <pattern id="pat-orange-{{ _id }}" patternUnits="userSpaceOnUse" width="10" height="10">
      <rect width="10" height="10" fill="#f77f28"/>
      <circle cx="2"   cy="2"   r="1.1" fill="#c05808" opacity="0.32"/>
      <circle cx="7"   cy="1.5" r="0.9" fill="#c05808" opacity="0.28"/>
      <circle cx="0.5" cy="6"   r="0.8" fill="#c05808" opacity="0.22"/>
      <circle cx="5"   cy="5.5" r="1.2" fill="#c05808" opacity="0.32"/>
      <circle cx="9"   cy="4.5" r="0.9" fill="#c05808" opacity="0.26"/>
      <circle cx="3"   cy="8.5" r="1.0" fill="#c05808" opacity="0.30"/>
      <circle cx="8"   cy="8"   r="0.9" fill="#c05808" opacity="0.25"/>
      <circle cx="2.5" cy="1.5" r="0.4" fill="#ffc080" opacity="0.55"/>
      <circle cx="5.5" cy="5"   r="0.4" fill="#ffc080" opacity="0.50"/>
      <circle cx="8.5" cy="8.5" r="0.3" fill="#ffc080" opacity="0.45"/>
    </pattern>

  </defs>

  <!--
    Layout (für size=48):
      "Mix": x=4,   Breite≈84,  rotiert -5° um Mitte
      "it":  x=88,  Breite≈53,  aufrecht
      "Cup": x=154, Breite≈91,  rotiert +4° um Mitte
    Gesamt-Breite ≈ _size * 5.4
    Alle y-Baseline bei _size * 1.1, damit Oberlängen nicht abgeschnitten werden.
  -->

  {% set _base = (_size * 1.1) | round %}
  {#
    x-Positionen (Fredoka One, font-size = _size):
      "Mix" startet bei x=4, Breite ≈ _size * 1.75
      "it"  startet direkt dahinter, Breite ≈ _size * 1.1
      "Cup" startet nach einem Gap von ≈ _size * 0.28
    Rotationen um die jeweilige Baseline-Mitte:
      "Mix" -5° um (x + halbe Breite, _base)
      "Cup" +4° um (x + halbe Breite, _base)
  #}
  {% set _xMix = 4 %}
  {% set _wMix = (_size * 1.75) | round %}
  {% set _xIt  = (_xMix + _wMix) %}
  {% set _wIt  = (_size * 1.1) | round %}
  {% set _xCup = (_xIt + _wIt | round) %}
  {% set _wCup = (_size * 1.9) | round %}

  <!-- "Mix" – leicht nach links geneigt (-5°) -->
  <text
    x="{{ _xMix }}"
    y="{{ _base }}"
    font-family="'Fredoka One', 'Nunito', system-ui, sans-serif"
    font-size="{{ _size }}"
    font-weight="900"
    fill="url(#pat-strawberry-{{ _id }})"
    transform="rotate(-5, {{ _xMix + (_wMix / 2) | round }}, {{ _base }})"
  >Mix</text>

  <!-- "it" – aufrecht, direkt nach "Mix" -->
  <text
    x="{{ _xIt }}"
    y="{{ _base }}"
    font-family="'Fredoka One', 'Nunito', system-ui, sans-serif"
    font-size="{{ _size }}"
    font-weight="900"
    fill="url(#pat-lime-{{ _id }})"
  >it</text>

  <!-- "Cup" – leicht nach rechts geneigt (+4°) -->
  <text
    x="{{ _xCup }}"
    y="{{ _base }}"
    font-family="'Fredoka One', 'Nunito', system-ui, sans-serif"
    font-size="{{ _size }}"
    font-weight="900"
    fill="url(#pat-orange-{{ _id }})"
    transform="rotate(4, {{ _xCup + (_wCup / 2) | round }}, {{ _base }})"
  >Cup</text>

</svg>
