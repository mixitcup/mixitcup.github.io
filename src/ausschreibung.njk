<!-- ==================== WERTUNG ==================== -->
<section class="info-section">
  <div class="container">
    <div class="section-header">
      <h2>Wertungssystem</h2>
    </div>

    <div class="cards-grid" style="max-width:900px; margin:0 auto;">

      <div class="card">
        <div class="card-accent" style="background: var(--color-blueberry);"></div>
        <div class="card-icon">📐</div>
        <h3>Pflichtübung (Synchron)</h3>
        <ul>
          <li>
          Bewertet von <strong>4 Haltungs-</strong> und <strong>2 Synchronkampfrichter*innen</strong>.
          </li>
          <li>
          Haltungs- und Synchronwertung werden gemittelt. 
          </li>
          <li>
          Maximal <strong>40 Punkte</strong> pro Mannschaft.
          </li>
        </ul>
      </div>

      <div class="card">
        <div class="card-accent" style="background: var(--color-strawberry);"></div>
        <div class="card-icon">💃</div>
        <h3>Paarungstanz (Kür)</h3>
        <ul>
        <li>
          20 Sprünge, jedes Teammitglied springt 5. 
          </li>
          <li>
          Bewertet von <strong>4 Haltungs-</strong> und <strong>2 Schwierigkeitskampfrichter*innen</strong>. 
          </li>
          <li>
          Haltungswert max. <strong>20 Punkte</strong>.
          </li>
          <li>
          Die zwei mittleren Haltungswerte + Schwierigkeit = Gesamtpunktzahl.
          </li>
        </ul>
      </div>

    </div>
  </div>
</section>

